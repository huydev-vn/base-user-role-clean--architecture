{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=base-phan-quyen;Username=postgres;Password=YOUR_DB_PASSWORD_HERE"
  },
  "JwtSettings": {
    "Secret": "CHANGE_THIS_TO_A_STRONG_SECRET_AT_LEAST_32_CHARS",
    "Issuer": "BASE.API",
    "Audience": "BASE.API",
    "ExpiryMinutes": 15
  },
  "LockoutSettings": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
